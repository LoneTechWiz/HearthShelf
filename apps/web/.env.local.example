# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/personal_library

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL — defaults to localhost:3000; set this if accessing from another device (e.g. phone testing)
# AUTH_URL=http://192.168.1.x:3000

# GitHub OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
